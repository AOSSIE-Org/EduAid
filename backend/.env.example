# EduAid Backend Configuration

# ============================================
# INFERENCE MODE CONFIGURATION
# ============================================
# Set to 'true' to use Celery workers for inference (memory-efficient, requires Redis)
# Set to 'false' to load models directly in Flask (legacy mode, uses more memory)
USE_CELERY_INFERENCE=false

# ============================================
# ASYNC ENDPOINTS CONFIGURATION
# ============================================
# Set to 'true' to enable async endpoints (/generate_mcq_async, etc.)
# Set to 'false' to disable async endpoints (safer until frontend is ready)
# Note: Async endpoints require USE_CELERY_INFERENCE=true
USE_ASYNC=false

# ============================================
# REDIS CONFIGURATION (required if USE_CELERY_INFERENCE=true)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# FLASK CONFIGURATION
# ============================================
FLASK_ENV=development
FLASK_DEBUG=1

